{
  "apiVersion": 3,
  "name": "margarita/measurements",
  "title": "Margarita Measurements",
  "category": "widgets",
  "icon": "carrot",
  "description": "Interactive margarita calculator.",
  "keywords": [
    "cocktail",
    "margarita",
    "drink",
    "calculator"
  ],
  "editorScript": "file:./editor.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "supports": {
    "html": false
  },
  "attributes": {
    "preset": {
      "type": "string",
      "default": "classic"
    },
    "unit": {
      "type": "string",
      "default": "ml"
    },
    "flavour": {
      "type": "string",
      "default": "none"
    },
    "mode": {
      "type": "string",
      "default": "drinks"
    },
    "showAbv": {
      "type": "boolean",
      "default": true
    },
    "title": {
      "type": "string",
      "default": "Margarita Measurements"
    }
  }
}
